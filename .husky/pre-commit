#!/usr/bin/env sh
set -e

# ── Lean pre-commit gate set (ADR-018 §5 / #52) ──────────────────────────────
# Fast, deterministic, environment-agnostic: no network fetches, no browser, no
# binary downloads. This ends the --no-verify era — every gate here runs in any
# environment (local, CI, remote agent sessions).
#
# The full 56-gate guardrail registry (docs/guardrails/registry.json) and its
# scripts/check-*.mjs / scripts/audit-*.mjs are ARCHIVED IN PLACE, not deleted:
# recoverable, still runnable on demand (`node scripts/run-gates.mjs --channel
# ci-pr` in CI, or any gate directly), just no longer wired into the hooks. The
# Swiss-canon rules remain as documentation.

echo "Secrets scan (gitleaks; skips gracefully if absent)…"
pnpm check:secrets

echo "Prettier (staged files)…"
pnpm exec lint-staged

echo "Typecheck…"
pnpm typecheck

echo "ESLint (zero warnings)…"
pnpm lint --max-warnings=0

echo "Token pipeline validity (verify-tokens + check-contrast)…"
node scripts/verify-tokens.mjs
node scripts/check-contrast.mjs
