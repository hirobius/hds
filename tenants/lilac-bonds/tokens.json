{
  "$schema": "../../hirobius.tenant-tokens.schema.json",
  "$description": "Lilac Bonds brand overlay — lilac accent over HDS brand-blue. Semantic tier only, per R1. Aliases {primitive.color.lilac.*} (added to hirobius.tokens.json in the same change; R5 requires alias targets to exist). NOT named violet: primitive.color.violet is the feedback palette as of 0.11.0 (different hexes and role). Dark-mode aliases mirror the base dark accent logic (rest 500, hover 450, pressed 400, subtle 900, content 300, contentHover 200). Authored downstream in hirobius/lilac-bonds (design-system/lilac-bonds.tenant-tokens.json) and upstreamed here verbatim.",

  "semantic": {
    "accent": {
      "$type": "color",
      "rest": {
        "$value": "{primitive.color.lilac.500}",
        "$description": "Lilac Bonds primary accent. AA for white text on both page and card surfaces.",
        "$extensions": {
          "com.figma.variables": {
            "modes": {
              "Light": "{primitive.color.lilac.500}",
              "Dark": "{primitive.color.lilac.500}"
            }
          }
        }
      },
      "hover": {
        "$value": "{primitive.color.lilac.600}",
        "$description": "Accent hover.",
        "$extensions": {
          "com.figma.variables": {
            "modes": {
              "Light": "{primitive.color.lilac.600}",
              "Dark": "{primitive.color.lilac.450}"
            }
          }
        }
      },
      "pressed": {
        "$value": "{primitive.color.lilac.700}",
        "$description": "Accent pressed.",
        "$extensions": {
          "com.figma.variables": {
            "modes": {
              "Light": "{primitive.color.lilac.700}",
              "Dark": "{primitive.color.lilac.400}"
            }
          }
        }
      },
      "subtle": {
        "$value": "{primitive.color.lilac.50}",
        "$description": "Faint accent tint.",
        "$extensions": {
          "com.figma.variables": {
            "modes": {
              "Light": "{primitive.color.lilac.50}",
              "Dark": "{primitive.color.lilac.900}"
            }
          }
        }
      },
      "content": {
        "$value": "{primitive.color.lilac.500}",
        "$description": "Accent text/links.",
        "$extensions": {
          "com.figma.variables": {
            "modes": {
              "Light": "{primitive.color.lilac.500}",
              "Dark": "{primitive.color.lilac.300}"
            }
          }
        }
      },
      "contentHover": {
        "$value": "{primitive.color.lilac.600}",
        "$description": "Accent text hover.",
        "$extensions": {
          "com.figma.variables": {
            "modes": {
              "Light": "{primitive.color.lilac.600}",
              "Dark": "{primitive.color.lilac.200}"
            }
          }
        }
      },
      "disabled": {
        "$value": "{primitive.color.lilac.100}",
        "$description": "Disabled accent.",
        "$extensions": {
          "com.figma.variables": {
            "modes": {
              "Light": "{primitive.color.lilac.100}",
              "Dark": "{primitive.color.lilac.100}"
            }
          }
        }
      },
      "inactive": {
        "$value": "{primitive.color.lilac.200}",
        "$description": "Inactive accent.",
        "$extensions": {
          "com.figma.variables": {
            "modes": {
              "Light": "{primitive.color.lilac.200}",
              "Dark": "{primitive.color.lilac.200}"
            }
          }
        }
      }
    },
    "color": {
      "$type": "color",
      "surface": {
        "accent": {
          "$value": "{primitive.color.lilac.500}",
          "$description": "Accent surface fill — CTAs, primary buttons.",
          "$extensions": {
            "com.figma.variables": {
              "modes": {
                "Light": "{primitive.color.lilac.500}",
                "Dark": "{primitive.color.lilac.500}"
              }
            }
          }
        },
        "accentSubtle": {
          "$value": "{primitive.color.lilac.50}",
          "$description": "Faint accent tint surface.",
          "$extensions": {
            "com.figma.variables": {
              "modes": {
                "Light": "{primitive.color.lilac.50}",
                "Dark": "{primitive.color.lilac.900}"
              }
            }
          }
        }
      },
      "border": {
        "accent": {
          "$value": "{primitive.color.lilac.500}",
          "$description": "Accent border / focus ring.",
          "$extensions": {
            "com.figma.variables": {
              "modes": {
                "Light": "{primitive.color.lilac.500}",
                "Dark": "{primitive.color.lilac.500}"
              }
            }
          }
        }
      },
      "content": {
        "accent": {
          "$value": "{primitive.color.lilac.500}",
          "$description": "Accent content colour.",
          "$extensions": {
            "com.figma.variables": {
              "modes": {
                "Light": "{primitive.color.lilac.500}",
                "Dark": "{primitive.color.lilac.300}"
              }
            }
          }
        }
      }
    }
  }
}
