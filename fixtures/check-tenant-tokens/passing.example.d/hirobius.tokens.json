{
  "$schema": "https://www.designtokens.org/schemas/2025.10/format.json",
  "$description": "Minimal fixture base tokens for check-tenant-tokens proof-of-firing.",
  "primitive": {
    "color": {
      "$type": "color",
      "blue": {
        "500": {
          "$value": "#3b82f6",
          "$description": "Brand blue mid-ramp."
        }
      }
    }
  },
  "semantic": {
    "color": {
      "$type": "color",
      "surface": {
        "accent": {
          "$value": "{primitive.color.blue.500}",
          "$description": "Accent surface fill."
        }
      }
    },
    "radius": {
      "action": {
        "$type": "dimension",
        "$value": { "value": 12, "unit": "px" },
        "$description": "Corner radius for interactive action elements."
      }
    },
    "space": {
      "$type": "dimension",
      "component": {
        "padding": {
          "$value": { "value": 24, "unit": "px" },
          "$description": "Default component inset."
        }
      }
    },
    "borderWidth": {
      "default": {
        "$type": "dimension",
        "$value": { "value": 1, "unit": "px" },
        "$description": "Default hairline border weight."
      }
    }
  },
  "role": {
    "radius": {
      "$type": "dimension",
      "$value": "{semantic.radius.action}",
      "$description": "Default border radius."
    }
  }
}
